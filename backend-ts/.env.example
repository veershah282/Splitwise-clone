# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/splitwise

# Authentication (Generate strong random strings)
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# AI Features (Google Gemini)
# Get a key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Email Service (Resend)
# Get a key from: https://resend.com/
RESEND_API_KEY=your_resend_api_key_here
MAIL_FROM=Splitwise AI <onboarding@resend.dev>

# Development Overrides
# Set this to your own email to test summaries regardless of logged-in user
# MAIL_TO_OVERRIDE=test@example.com

# CORS Settings (Comma-separated list of allowed origins)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate Limiting
AI_RATE_LIMIT_WINDOW_MS=60000
AI_RATE_LIMIT_MAX=20
